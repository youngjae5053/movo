# Copy this file to `.env.local` in the project root.

# Supabase project URL
# Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key
# Dashboard → Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: service role key (server-only scripts / admin tasks)
# NEVER expose this in client-side code or commit it to git.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# After pulling latest, run in Supabase SQL Editor:
# supabase/migrations/002_workout_media.sql
# (creates workout-media storage bucket + media table)
